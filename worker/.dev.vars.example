# Copy to .dev.vars (gitignored) for local wrangler dev
# Production secrets are set with: wrangler secret put <NAME>

# Sketchfab Data API token — free, primary path
# https://sketchfab.com/settings/password → API token
SKETCHFAB_API_KEY=

# Tripo AI — optional generative fallback used only if Sketchfab returns no match
# https://platform.tripo3d.ai → Settings → API Keys
TRIPO_API_KEY=

# Set to your deployed worker URL for webhook callbacks from Tripo
# Leave blank during local dev — pipeline will poll instead
WORKER_URL=
