# Copy to .dev.vars (gitignored) for local wrangler dev
# Production secrets are set with: wrangler secret put <NAME>

# 2D image generation: Pollinations.ai — free, no key needed

# Tripo AI — fast draft-tier 3D (~8s)
# https://platform.tripo3d.ai → Settings → API Keys
TRIPO_API_KEY=

# Meshy AI — PBR production-tier 3D
# https://app.meshy.ai → avatar → API Keys
MESHY_API_KEY=

# Set to your deployed worker URL for webhook callbacks from Tripo/Meshy
# Leave blank during local dev — pipeline will poll instead
WORKER_URL=
