{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ojet3d-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],

  "durable_objects": {
    "bindings": [
      { "name": "JOBS", "class_name": "JobStore" }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["JobStore"] }
  ],

  "observability": {
    "enabled": true
  }
}
