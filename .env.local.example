# Copy this file to .env.local and fill in your keys
# Keys are used client-side in dev only — add a backend proxy before shipping to production

# Prodia — 2D image generation (free tier available)
# https://app.prodia.com/api
VITE_PRODIA_API_KEY=

# Tripo AI — fast image-to-3D, ~8s draft tier
# https://platform.tripo3d.ai
VITE_TRIPO_API_KEY=

# Meshy AI — high-fidelity PBR image-to-3D, production tier
# https://app.meshy.ai
VITE_MESHY_API_KEY=
