# Copy to .env.local and fill in your keys

# Cloudflare Worker URL — when set, generation runs server-side via Sketchfab
# Leave blank to fall back to direct browser path (Tripo or sample GLB)
VITE_WORKER_URL=

# Tripo AI — optional generative fallback ($0.10–0.15 per generation)
# Only used in local dev path when VITE_WORKER_URL is blank.
# https://platform.tripo3d.ai → Settings → API Keys
VITE_TRIPO_API_KEY=
