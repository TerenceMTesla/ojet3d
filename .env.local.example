# Copy to .env.local and fill in your keys

# Cloudflare Worker URL — when set, all generation runs server-side (tab-safe)
# Leave blank to run the pipeline directly in the browser (dev mode)
VITE_WORKER_URL=

# 2D Image Generation
# Pollinations.ai is free with no key — no entry needed here.
# If you want to swap providers later, add a key here and update pipeline.ts.

# Tripo AI — fast image-to-3D, ~8s draft tier
# https://platform.tripo3d.ai → Settings → API Keys
VITE_TRIPO_API_KEY=

# Meshy AI — high-fidelity PBR image-to-3D, production tier
# https://app.meshy.ai → avatar → API Keys
VITE_MESHY_API_KEY=
